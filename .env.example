# ── API Keys (for LLM calls in engine + Chainlink Functions) ──
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
NEWS_API_KEY=...

# ── Blockchain ──
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-key
DEPLOYER_PRIVATE_KEY=0x...

# ── Chainlink (set after creating subscription at functions.chain.link) ──
CHAINLINK_SUBSCRIPTION_ID=

# ── Contract (set automatically by setup-sepolia.ts) ──
VITE_CONTRACT_ADDRESS=
CONTRACT_ADDRESS=

# ── Engine API Server ──
API_PORT=3001
RPC_URL=http://127.0.0.1:8545
USE_MOCKS=true
